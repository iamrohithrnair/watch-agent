{
  "name": "watchagent",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=24 <25",
    "npm": ">=11"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @watchagent/gateway",
    "dev:gateway": "npm run dev -w @watchagent/gateway",
    "dev:web": "npm run dev -w @watchagent/web",
    "build": "npm run build -ws",
    "check": "npm run check --workspaces",
    "check:env": "tsx packages/core/src/scripts/check-env.ts",
    "verify:live": "tsx packages/core/src/scripts/verify-live.ts",
    "typecheck": "tsc -b"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "tsx": "^4.20.5",
    "typescript": "^5.7.3"
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "^2.0.49",
    "ai": "^6.0.202"
  }
}
